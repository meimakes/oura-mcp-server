{
  "name": "oura-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for accessing Oura Ring data via OAuth2",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "jest",
    "test:integration": "jest --testPathPattern=integration",
    "test:oauth": "jest --testPathPattern=oauth",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "oura",
    "mcp",
    "oauth2",
    "health",
    "wearables",
    "model-context-protocol",
    "poke",
    "oura-ring"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/meimakes/oura-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/meimakes/oura-mcp-server/issues"
  },
  "homepage": "https://github.com/meimakes/oura-mcp-server#readme",
  "dependencies": {
    "axios": "^1.13.5",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "joi": "^17.13.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "eslint": "^9.39.0",
    "jest": "^30.2.0",
    "@jest/globals": "^30.2.0",
    "nodemon": "^3.1.13",
    "ts-jest": "^29.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.56.0"
  },
  "overrides": {
    "glob": "^13.0.0",
    "minimatch": "^10.2.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
